#!/usr/bin/env bash
# harness — Main CLI entry point for the dev-harness workflow
# Usage:
#   harness init [dir]     — Bootstrap .harness/ in a project
#   harness build [dir]    — Launch Claude Code as Builder
#   harness review [dir]   — Launch Codex as Reviewer
#   harness loop [dir]     — Run one full build→review cycle
#   harness status [dir]   — Show current harness state
#   harness context [dir]  — Auto-generate context-map from codebase

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    init)
        exec "${SCRIPT_DIR}/harness-init.sh" "$@"
        ;;
    build)
        exec "${SCRIPT_DIR}/build.sh" "$@"
        ;;
    review)
        exec "${SCRIPT_DIR}/review.sh" "$@"
        ;;
    loop)
        exec "${SCRIPT_DIR}/loop.sh" "$@"
        ;;
    status)
        TARGET_DIR="${1:-.}"
        TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"
        HARNESS_DIR="${TARGET_DIR}/.harness"

        if [[ ! -d "$HARNESS_DIR" ]]; then
            echo "No .harness/ found at ${TARGET_DIR}"
            exit 1
        fi

        echo "=== Harness Status ==="
        echo "Project: $(basename "$TARGET_DIR")"
        echo ""

        # Count tasks by status
        if [[ -f "${HARNESS_DIR}/coordination/task-board.md" ]]; then
            echo "Tasks:"
            echo "  Backlog:     $(grep -c '|.*|.*|.*|.*|.*|' "${HARNESS_DIR}/coordination/task-board.md" 2>/dev/null || echo 0) rows"
        fi

        # Count handoffs and reviews
        HANDOFFS=$(ls "${HARNESS_DIR}/handoffs/"handoff_*.md 2>/dev/null | wc -l | tr -d ' ')
        REVIEWS=$(ls "${HARNESS_DIR}/reviews/"review_*.md 2>/dev/null | wc -l | tr -d ' ')
        echo "  Handoffs:    ${HANDOFFS}"
        echo "  Reviews:     ${REVIEWS}"

        # Show latest activity
        echo ""
        echo "Latest progress:"
        tail -5 "${HARNESS_DIR}/coordination/progress-log.md" 2>/dev/null || echo "  (no entries)"
        ;;
    context)
        TARGET_DIR="${1:-.}"
        TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"
        HARNESS_DIR="${TARGET_DIR}/.harness"

        if [[ ! -d "$HARNESS_DIR" ]]; then
            echo "No .harness/ found at ${TARGET_DIR}. Run: harness init"
            exit 1
        fi

        PROMPT="Read the codebase and generate a comprehensive context-map.
Write the result to .harness/coordination/context-map.md using the existing template format.
Include: directory structure, key modules, critical paths, conventions, and external dependencies.
Be factual — only document what actually exists in the code."

        echo "=== Generating Context Map (Claude Code) ==="
        cd "$TARGET_DIR" && claude --print "$PROMPT" > /dev/null
        echo "Done. See: .harness/coordination/context-map.md"
        ;;
    uninstall)
        HARNESS_HOME="${HOME}/.dev-harness"
        if [[ -f "${HARNESS_HOME}/scripts/uninstall.sh" ]]; then
            exec "${HARNESS_HOME}/scripts/uninstall.sh"
        else
            echo "Error: uninstall.sh not found. Reinstall dev-harness first."
            exit 1
        fi
        ;;
    help|--help|-h)
        echo "harness — Dual-agent development workflow"
        echo ""
        echo "Usage: harness <command> [project_dir]"
        echo ""
        echo "Commands:"
        echo "  init      Bootstrap .harness/ in a project"
        echo "  build     Launch Claude Code as Builder agent"
        echo "  review    Launch Codex as Reviewer agent"
        echo "  loop      Run one full build→review cycle"
        echo "  status    Show current harness state"
        echo "  context   Auto-generate context-map from codebase"
        echo "  uninstall Remove dev-harness from this machine"
        echo ""
        echo "Workflow:"
        echo "  1. harness init ~/my-project"
        echo "  2. Edit .harness/coordination/task-board.md"
        echo "  3. harness build  (or harness loop for full cycle)"
        ;;
    *)
        echo "Unknown command: $COMMAND"
        echo "Run 'harness help' for usage."
        exit 1
        ;;
esac
